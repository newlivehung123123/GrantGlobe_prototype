# GrantGlobe Stage 2 — environment variable reference
# Copy to .env and fill in real values.  Never commit .env.

# Cookie encryption (required for Profile B cookie session injection)
COOKIE_ENCRYPTION_KEY=<your-fernet-key>

# Proxy credentials (required only when PROXY_ENABLED=True in settings.py)
PROXY_HOST=
PROXY_PORT=
PROXY_USERNAME=
PROXY_PASSWORD=

# Alert delivery (at least one of email or webhook)
ALERT_EMAIL_HOST=smtp.example.com
ALERT_EMAIL_PORT=587
ALERT_EMAIL_USER=alerts@example.com
ALERT_EMAIL_PASSWORD=
ALERT_EMAIL_FROM=alerts@example.com
ALERT_EMAIL_TO=oncall@example.com
ALERT_WEBHOOK_URL=
